---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AuthorLink from '../components/AuthorLink.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { url } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: { depth: number; slug: string; text: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, authors, id, headings } = Astro.props;
const fallbackHero = id ? url(`/blog/${id}.png`) : url('/og.png');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 100%;
				height: auto;
			}
			.blog-container {
				display: flex;
				flex-direction: column;
				max-width: 1200px;
				margin: 0 auto;
				padding: 1rem;
			}
			.prose {
				width: 760px;
				max-width: 100%;
				color: rgb(var(--gray-dark));
			}
			.prose :global(p) {
				text-align: justify;
				hyphens: auto;
			}
			.toc-sidebar {
				display: none;
			}

			@media (min-width: 1024px) {
				.blog-container {
					flex-direction: row-reverse;
					justify-content: center;
					align-items: flex-start;
					gap: 2rem;
				}
				.toc-sidebar {
					display: block;
					position: sticky;
					top: 2rem;
					width: 250px;
					flex-shrink: 0;
				}
				.prose {
					margin: 0;
				}
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.blog-authors {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.75rem;
				font-size: 0.9rem;
				color: var(--color-text-muted);
			}
			.blog-authors span {
				font-size: 0.9rem;
			}
			.mobile-toc {
				display: block;
				margin-bottom: 2rem;
			}

			@media (min-width: 1024px) {
				.mobile-toc {
					display: none;
				}
			}

			@media (max-width: 768px) {
				.title h1 {
					font-size: 1.6rem;
				}
				.prose {
					padding: 1rem 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt={title} />
					) : (
						<img width={1020} height={510} src={fallbackHero} alt={title} />
					)}
				</div>
				<div class="blog-container">
					{headings && headings.length > 0 && (
						<aside class="toc-sidebar">
							<TableOfContents headings={headings} />
						</aside>
					)}
					<div class="prose">
						<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{authors && authors.length > 0 && (
							<div class="blog-authors">
								{authors.map((authorId, i) => (
									<span>
										<AuthorLink nameOrSlug={authorId} />
										{i < authors.length - 1 ? ', ' : ''}
									</span>
								))}
							</div>
						)}
						<hr />
					</div>

					{/* Mobile TOC */}
					{headings && headings.length > 0 && (
						<div class="mobile-toc">
							<TableOfContents headings={headings} />
						</div>
					)}

					<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
