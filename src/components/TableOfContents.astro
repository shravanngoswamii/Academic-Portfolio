---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav class="toc">
    <div class="toc-header">Table of Contents</div>
    <ul class="toc-list">
      {headings.map((heading) => (
        <li class={`toc-item toc-level-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    background: var(--color-bg-offset);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    font-size: 0.9rem;
  }
  .toc-header {
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text-main);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-item {
    margin-bottom: 0.25rem;
  }
  .toc-item a {
    color: var(--color-text-muted);
    text-decoration: none;
    display: block;
    transition: color 0.2s ease;
  }
  .toc-item a:hover {
    color: var(--color-accent);
  }
  .toc-item.active > a {
    color: var(--color-accent);
    font-weight: 600;
  }
  .toc-level-2 {
    margin-left: 0;
  }
  .toc-level-3 {
    margin-left: 1rem;
  }
  .toc-level-4 {
    margin-left: 2rem;
  }
</style>

<script>
  function initTOC() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.getAttribute('id');
          if (!id) return;

          const tocLink = document.querySelector(`.toc-item a[href="#${id}"]`);
          if (!tocLink) return;

          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-item').forEach((item) => {
              item.classList.remove('active');
            });
            tocLink.parentElement?.classList.add('active');
          }
        });
      },
      { rootMargin: '0px 0px -80% 0px' }
    );

    document.querySelectorAll('h2, h3, h4, h5, h6').forEach((section) => {
      observer.observe(section);
    });
  }

  // Initialize on page load and astro page navigation
  document.addEventListener('astro:page-load', initTOC);
  if (document.readyState === 'complete') {
    initTOC();
  } else {
    document.addEventListener('DOMContentLoaded', initTOC);
  }
</script>