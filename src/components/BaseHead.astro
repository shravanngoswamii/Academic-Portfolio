---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';
import { url } from '../utils/paths';

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

let defaultImg = '/og.png';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
let currentPath = Astro.url.pathname;
if (currentPath.startsWith(basePath)) {
    currentPath = currentPath.substring(basePath.length);
}
currentPath = currentPath.replace(/^\/|\/$/g, '');

if (currentPath === '') {
    defaultImg = '/og.png';
} else {
    defaultImg = `/${currentPath}.png`;
}

const { title, description, image = defaultImg } = Astro.props;

const resolveImage = (img: string) => {
    if (img.startsWith('http')) return img;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
    if (img.startsWith(base)) return img;
    return `${base}${img.replace(/^\//, '')}`;
};

const imageUrl = typeof image === 'string'
	? new URL(resolveImage(image), Astro.url)
	: new URL(image.src, Astro.url);
---

<meta charset="utf-8" />
<script is:inline>
	(() => {
		/** @typedef {'light' | 'dark'} Theme */
		/** @typedef {Window & typeof globalThis & { __setPreferredTheme?: (theme: Theme) => Theme }} ThemeWindow */

		const root = document.documentElement;
		const themeWindow = /** @type {ThemeWindow} */ (window);
		const darkBackground = '#0f172a';
		const lightBackground = '#ffffff';

		/** @type {(theme: Theme | string | null | undefined) => Theme} */
		const paintTheme = (theme) => {
			const resolvedTheme = theme === 'dark' ? 'dark' : 'light';
			const backgroundColor = resolvedTheme === 'dark' ? darkBackground : lightBackground;

			root.setAttribute('data-theme', resolvedTheme);
			root.style.backgroundColor = backgroundColor;
			root.style.colorScheme = resolvedTheme;

			if (document.body) {
				document.body.style.backgroundColor = backgroundColor;
			}

			return resolvedTheme;
		};

		/** @type {Theme} */
		let theme = 'light';

		try {
			const storedTheme = localStorage.getItem('theme');
			if (storedTheme === 'dark' || storedTheme === 'light') {
				theme = storedTheme;
			} else if (themeWindow.matchMedia('(prefers-color-scheme: dark)').matches) {
				theme = 'dark';
			}
		} catch {
			if (themeWindow.matchMedia('(prefers-color-scheme: dark)').matches) {
				theme = 'dark';
			}
		}

		/** @type {(nextTheme: Theme) => Theme} */
		themeWindow.__setPreferredTheme = (nextTheme) => {
			const resolvedTheme = paintTheme(nextTheme);
			root.setAttribute('data-theme-ready', 'true');
			return resolvedTheme;
		};

		paintTheme(theme);

		if (!document.body) {
			document.addEventListener(
				'DOMContentLoaded',
				() => {
					paintTheme(root.getAttribute('data-theme'));
				},
				{ once: true }
			);
		}

		const markReady = () => root.setAttribute('data-theme-ready', 'true');
		if (typeof themeWindow.requestAnimationFrame === 'function') {
			themeWindow.requestAnimationFrame(() => themeWindow.requestAnimationFrame(markReady));
		} else {
			setTimeout(markReady, 0);
		}
	})();
</script>
<style is:inline>
	html,
	body {
		min-height: 100%;
		background-color: #ffffff;
	}

	html[data-theme='light'],
	html[data-theme='light'] body {
		background-color: #ffffff;
		color-scheme: light;
	}

	html[data-theme='dark'],
	html[data-theme='dark'] body {
		background-color: #0f172a;
		color-scheme: dark;
	}
</style>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
<link rel="sitemap" href={url('/sitemap-index.xml')} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />

<link rel="preload" href={url('/fonts/atkinson-regular.woff')} as="font" type="font/woff" crossorigin />
<link rel="preload" href={url('/fonts/atkinson-bold.woff')} as="font" type="font/woff" crossorigin />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />
